# report-service — variáveis de ambiente

# Banco de dados PostgreSQL (report_db)
DATABASE_URL=postgresql+asyncpg://report_user:report_pass@localhost:5432/report_db

# Autenticação interna (deve ser igual em upload-service, processing-service e report-service)
INTERNAL_API_KEY=dev-internal-api-key-change-in-production

# Observabilidade
SERVICE_NAME=report-service
LOG_LEVEL=INFO
